---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import { Icon } from "astro-icon/components";
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  SITE_ICP,
  SITE_MPS_BEIAN,
} from "../consts";

interface Props {
  title?: string;
  description?: string;
  type?: "website" | "article";
  pubDate?: Date;
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  type = "website",
  pubDate,
} = Astro.props;
const canonicalUrl = new URL(
  Astro.url.pathname,
  Astro.site ?? Astro.url,
).toString();
---

<!doctype html>
<html lang="zh-cn">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="color-scheme" content="light dark" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_TITLE}
      href="/rss.xml"
    />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content="zh_CN" />
    {
      type === "article" && pubDate && (
        <meta
          property="article:published_time"
          content={pubDate.toISOString()}
        />
      )
    }
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <script is:inline>
      (() => {
        const storedTheme = (() => {
          try {
            return localStorage.getItem("theme");
          } catch {
            return null;
          }
        })();
        const prefersDark = window.matchMedia(
          "(prefers-color-scheme: dark)",
        ).matches;
        const theme = storedTheme ?? (prefersDark ? "dark" : "light");

        document.documentElement.classList.toggle("dark", theme === "dark");
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
    <ClientRouter fallback="swap" />
    <title>{title}</title>
  </head>
  <body
    class="bg-stone-50 text-stone-800 font-sans antialiased min-h-screen flex flex-col transition-colors dark:bg-stone-950 dark:text-stone-100"
  >
    <div
      data-page-progress
      data-astro-transition-persist="page-progress"
      class="page-progress"
    >
    </div>
    <header
      class="bg-white/80 backdrop-blur-md border-b border-stone-200 sticky top-0 z-50 transition-colors dark:bg-stone-950/80 dark:border-stone-800"
    >
      <nav
        class="max-w-3xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between"
      >
        <a
          href="/"
          class="text-lg font-semibold tracking-tight hover:text-stone-600 transition-colors dark:hover:text-stone-300"
        >
          {SITE_TITLE}
        </a>
        <div class="flex gap-5 text-sm text-stone-600 items-center dark:text-stone-400">
          <a href="/" class="hover:text-stone-900 transition-colors dark:hover:text-stone-100">首页</a>
          <a href="/about" class="hover:text-stone-900 transition-colors dark:hover:text-stone-100">关于</a>
          <button
            type="button"
            data-theme-toggle
            aria-label="切换夜间模式"
            class="inline-flex size-6 items-center justify-center hover:text-stone-900 transition-colors dark:hover:text-stone-100"
          >
            <Icon name="lucide:sun" class="hidden size-5 dark:block" />
            <Icon name="lucide:moon" class="size-5 dark:hidden" />
          </button>
          <a
            href="https://github.com/ll3me/diaryland"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="GitHub"
            class="hover:text-stone-900 transition-colors dark:hover:text-stone-100"
          >
            <Icon name="github" class="w-6 h-6" />
          </a>
        </div>
      </nav>
    </header>
      <main class="flex-grow max-w-3xl w-full mx-auto px-4 sm:px-6 py-12">
        <slot />
      </main>

      <footer
        class="max-w-3xl mx-auto px-4 sm:px-6 py-8 w-full border-t border-stone-200 text-center text-stone-500 text-xs transition-colors dark:border-stone-800 dark:text-stone-500"
      >
        <div class="space-y-1">
          <div>&copy; {new Date().getFullYear()} {SITE_TITLE}.</div>
          {
            (SITE_ICP || SITE_MPS_BEIAN) && (
              <div class="flex justify-center gap-4">
                {SITE_ICP && (
                  <a
                    href="https://beian.miit.gov.cn/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:underline"
                  >
                    {SITE_ICP}
                  </a>
                )}
                {SITE_MPS_BEIAN && (
                  <a
                    href="https://beian.mps.gov.cn/"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="hover:underline"
                  >
                    {SITE_MPS_BEIAN}
                  </a>
                )}
              </div>
            )
          }
        </div>
      </footer>
      <script is:inline>
        (() => {
          if (window.__diarylandThemeController) return;
          window.__diarylandThemeController = true;

          const getStoredTheme = () => {
            try {
              return localStorage.getItem("theme");
            } catch {
              return null;
            }
          };

          const getPreferredTheme = () => {
            const storedTheme = getStoredTheme();
            if (storedTheme) return storedTheme;

            return window.matchMedia("(prefers-color-scheme: dark)").matches
              ? "dark"
              : "light";
          };

          const applyTheme = (theme, root = document.documentElement) => {
            root.classList.toggle("dark", theme === "dark");
            root.style.colorScheme = theme;
          };

          const setupThemeToggle = () => {
            const toggle = document.querySelector("[data-theme-toggle]");
            if (!toggle || toggle.dataset.themeToggleBound) return;
            toggle.dataset.themeToggleBound = "true";

            toggle.addEventListener("click", () => {
              const currentTheme = document.documentElement.classList.contains(
                "dark",
              )
                ? "dark"
                : "light";
              const nextTheme = currentTheme === "dark" ? "light" : "dark";
              try {
                localStorage.setItem("theme", nextTheme);
              } catch {}
              applyTheme(nextTheme);
            });
          };

          document.addEventListener("astro:before-swap", (event) => {
            applyTheme(getPreferredTheme(), event.newDocument.documentElement);
          });

          document.addEventListener("astro:page-load", () => {
            applyTheme(getPreferredTheme());
            setupThemeToggle();
          });

          setupThemeToggle();
        })();
      </script>
      <script is:inline>
        (() => {
          if (window.__diarylandProgressController) return;
          window.__diarylandProgressController = true;

          let finishTimer;
          let resetTimer;
          let startedAt = 0;

          const getProgress = () =>
            document.querySelector("[data-page-progress]");

          const startProgress = () => {
            const progress = getProgress();
            if (!progress) return;

            clearTimeout(finishTimer);
            clearTimeout(resetTimer);
            startedAt = Date.now();
            progress.classList.remove("is-started", "is-complete");
            progress.classList.add("is-loading");

            requestAnimationFrame(() => {
              progress.classList.add("is-started");
            });
          };

          const finishProgress = () => {
            const progress = getProgress();
            if (!progress) return;

            const elapsed = Date.now() - startedAt;
            const remaining = Math.max(0, 220 - elapsed);

            finishTimer = window.setTimeout(() => {
              progress.classList.remove("is-started");
              progress.classList.add("is-complete");

              resetTimer = window.setTimeout(() => {
                progress.classList.remove("is-loading", "is-started", "is-complete");
              }, 260);
            }, remaining);
          };

          document.addEventListener("astro:before-preparation", startProgress);
          document.addEventListener("astro:page-load", finishProgress);
        })();
      </script>
  </body>
</html>
