---
import { Icon } from "astro-icon/components";
---

<div data-search-modal class="search-modal" hidden>
  <div data-search-overlay class="search-overlay"></div>
  <div
    role="dialog"
    aria-modal="true"
    aria-label="站内搜索"
    class="search-panel"
  >
    <div class="search-input-row">
      <Icon name="lucide:search" class="size-5 shrink-0 text-stone-400" />
      <input
        type="search"
        data-search-input
        placeholder="搜索文章..."
        autocomplete="off"
        spellcheck="false"
        class="search-input"
        aria-label="搜索关键词"
      />
      <kbd class="search-esc">ESC</kbd>
    </div>
    <div data-search-results class="search-results" aria-live="polite"></div>
  </div>
</div>

<script>
  const PAGEFIND_PATH = "/pagefind/pagefind.js";

  let pagefind: any = null;
  let loadFailed = false;
  let debounceTimer: number | undefined;

  const loadPagefind = async () => {
    if (pagefind || loadFailed) return pagefind;
    try {
      pagefind = await import(/* @vite-ignore */ PAGEFIND_PATH);
      await pagefind.options?.({ excerptLength: 20 });
    } catch {
      loadFailed = true;
    }
    return pagefind;
  };

  const escapeHtml = (value: string) =>
    value.replace(
      /[&<>"']/g,
      (char) =>
        ({
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#39;",
        })[char] ?? char,
    );

  const renderState = (results: HTMLElement, html: string) => {
    results.innerHTML = html;
  };

  const runSearch = async (query: string, results: HTMLElement) => {
    const trimmed = query.trim();
    if (!trimmed) {
      renderState(results, "");
      return;
    }

    const instance = await loadPagefind();
    if (!instance) {
      renderState(
        results,
        `<p class="search-empty">搜索索引在开发环境不可用，请运行 <code>pnpm build</code> 后预览。</p>`,
      );
      return;
    }

    const search = await instance.search(trimmed);
    if (search.results.length === 0) {
      renderState(
        results,
        `<p class="search-empty">没有找到与 “${escapeHtml(trimmed)}” 相关的内容。</p>`,
      );
      return;
    }

    const items = await Promise.all(
      search.results.slice(0, 8).map((result: any) => result.data()),
    );

    renderState(
      results,
      `<ul class="search-result-list">${items
        .map(
          (item: any) => `
            <li>
              <a href="${item.url}" class="search-result">
                <span class="search-result-title">${escapeHtml(item.meta?.title ?? item.url)}</span>
                <span class="search-result-excerpt">${item.excerpt}</span>
              </a>
            </li>`,
        )
        .join("")}</ul>`,
    );
  };

  const setup = () => {
    const modal = document.querySelector<HTMLElement>("[data-search-modal]");
    const input = document.querySelector<HTMLInputElement>("[data-search-input]");
    const results = document.querySelector<HTMLElement>("[data-search-results]");
    const overlay = document.querySelector<HTMLElement>("[data-search-overlay]");
    if (!modal || !input || !results) return;

    const open = () => {
      modal.hidden = false;
      document.documentElement.classList.add("search-open");
      window.requestAnimationFrame(() => input.focus());
      loadPagefind();
    };

    const close = () => {
      modal.hidden = true;
      document.documentElement.classList.remove("search-open");
      input.value = "";
      renderState(results, "");
    };

    document.querySelectorAll("[data-search-trigger]").forEach((trigger) => {
      trigger.addEventListener("click", open);
    });

    overlay?.addEventListener("click", close);

    input.addEventListener("input", () => {
      window.clearTimeout(debounceTimer);
      debounceTimer = window.setTimeout(() => runSearch(input.value, results), 180);
    });

    document.addEventListener("keydown", (event) => {
      const isShortcut =
        (event.metaKey || event.ctrlKey) && event.key.toLowerCase() === "k";
      if (isShortcut) {
        event.preventDefault();
        modal.hidden ? open() : close();
        return;
      }
      if (event.key === "Escape" && !modal.hidden) {
        close();
      }
    });
  };

  document.addEventListener("astro:page-load", setup);
</script>
