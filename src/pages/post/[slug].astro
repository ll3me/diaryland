---
import { getCollection } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import Blog from '../../layouts/Blog.astro'
import { Icon } from 'astro-icon/components'
import { SITE_TITLE } from '../../consts'
import { getPostNavigation, getPostPath, getPosts, getSeriesPath } from '../../lib/posts'
import type { PostNavigation } from '../../lib/posts'
import { getPostTags, getTagPath, validatePostTags } from '../../lib/tags'
import type { TagItem } from '../../lib/tags'

export async function getStaticPaths() {
  const posts = await getPosts()
  const series = await getCollection('series')
  const tags = await getCollection('tags')
  validatePostTags(posts, tags)

  return posts.map(entry => ({
    params: { slug: entry.slug },
    props: {
      entry,
      navigation: getPostNavigation(entry, posts, series),
      tags: getPostTags(entry, tags),
    },
  }))
}

interface Props {
  entry: CollectionEntry<'posts'>
  navigation: PostNavigation | null
  tags: Pick<TagItem, 'title' | 'slug'>[]
}

const { entry, navigation, tags } = Astro.props
const { Content, headings } = await entry.render()
const tocHeadings = headings.filter(heading => heading.depth >= 2 && heading.depth <= 3)
---

<Blog
  title={`${entry.data.title} - ${SITE_TITLE}`}
  description={entry.data.description}
  type="article"
  pubDate={entry.data.pubDate}
>
  <article class="prose prose-stone max-w-none mt-6 dark:prose-invert">
    <h1 class="text-3xl font-bold mb-4">{entry.data.title}</h1>
    <div class="text-stone-500 mb-8 text-sm dark:text-stone-400">
      <p class="flex items-center gap-1">
        <Icon name="lucide:calendar-arrow-up" class="size-5" />
        {entry.data.pubDate.toLocaleDateString('zh-CN')}
        {
          entry.data.draft && (
            <span class="ml-2 rounded-md border border-amber-200 px-2 py-0.5 font-mono text-xs text-amber-700 dark:border-amber-900 dark:text-amber-400">
              草稿
            </span>
          )
        }
      </p>
      {
        tags.length > 0 && (
          <ul class="mt-3 flex flex-wrap gap-2">
            {tags.map(tag => (
              <li>
                <a
                  href={getTagPath(tag)}
                  class="inline-flex items-center gap-1 rounded-md border border-stone-200 px-2 py-1 font-mono text-xs text-stone-500 transition-colors hover:border-stone-300 hover:text-stone-900 dark:border-stone-800 dark:text-stone-400 dark:hover:border-stone-700 dark:hover:text-stone-100"
                >
                  <Icon name="lucide:tag" class="size-3" />
                  {tag.title}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
    {
      tocHeadings.length > 0 && (
        <nav
          aria-labelledby="toc-heading"
          class="not-prose mb-8 rounded-lg border border-stone-200 bg-white/60 p-4 dark:border-stone-800 dark:bg-stone-950/40"
        >
          <h2
            id="toc-heading"
            class="mb-3 flex items-center gap-2 text-sm font-semibold text-stone-800 dark:text-stone-100"
          >
            <Icon name="lucide:list" class="size-4 text-blue-700 dark:text-sky-400" />
            目录
          </h2>
          <ol class="space-y-2 text-sm leading-relaxed">
            {tocHeadings.map(heading => (
              <li class={heading.depth === 3 ? 'pl-4' : undefined}>
                <a
                  href={`#${heading.slug}`}
                  class="text-stone-500 transition-colors hover:text-stone-900 hover:underline dark:text-stone-400 dark:hover:text-stone-100"
                >
                  {heading.text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }
    <div class="text-stone-800 dark:text-stone-200">
      <Content />
    </div>
    {
      navigation?.type === 'series' && (
        <nav
          aria-label="系列文章导航"
          class="not-prose mt-10 border-y border-stone-200 py-5 dark:border-stone-800"
        >
          <div class="mb-4 flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <a
              href={getSeriesPath(navigation.series)}
              class="inline-flex items-center gap-2 font-medium text-stone-800 transition-colors hover:text-stone-500 hover:underline dark:text-stone-100 dark:hover:text-stone-300"
            >
              <Icon name="lucide:rows-3" class="size-4 text-blue-700 dark:text-sky-400" />
              {navigation.series.title}
            </a>
            <span class="font-mono text-sm text-stone-400 dark:text-stone-500">
              第 {navigation.index + 1} / {navigation.total} 篇
            </span>
          </div>
          <div class="grid gap-3 sm:grid-cols-2">
            {navigation.previous && (
              <a
                href={getPostPath(navigation.previous)}
                class="group flex min-h-20 flex-col justify-between rounded-lg border border-stone-200 p-3 transition-colors hover:border-stone-300 hover:bg-stone-100 dark:border-stone-800 dark:hover:border-stone-700 dark:hover:bg-stone-900"
              >
                <span class="flex items-center gap-1 font-mono text-xs text-stone-400 dark:text-stone-500">
                  <Icon
                    name="lucide:arrow-left"
                    class="size-3.5 transition-transform group-hover:-translate-x-1"
                  />
                  系列上一篇
                </span>
                <span class="mt-2 text-sm font-medium leading-relaxed text-stone-700 dark:text-stone-200">
                  {navigation.previous.data.title}
                </span>
              </a>
            )}
            {navigation.next && (
              <a
                href={getPostPath(navigation.next)}
                class="group flex min-h-20 flex-col justify-between rounded-lg border border-stone-200 p-3 text-right transition-colors hover:border-stone-300 hover:bg-stone-100 dark:border-stone-800 dark:hover:border-stone-700 dark:hover:bg-stone-900"
              >
                <span class="flex items-center justify-end gap-1 font-mono text-xs text-stone-400 dark:text-stone-500">
                  系列下一篇
                  <Icon
                    name="lucide:arrow-right"
                    class="size-3.5 transition-transform group-hover:translate-x-1"
                  />
                </span>
                <span class="mt-2 text-sm font-medium leading-relaxed text-stone-700 dark:text-stone-200">
                  {navigation.next.data.title}
                </span>
              </a>
            )}
          </div>
        </nav>
      )
    }
    {
      navigation?.type === 'timeline' && (
        <nav
          aria-label="文章时间线导航"
          class="not-prose mt-10 grid gap-3 border-y border-stone-200 py-5 dark:border-stone-800 sm:grid-cols-2"
        >
          {navigation.previous && (
            <a
              href={getPostPath(navigation.previous)}
              class="group flex min-h-20 flex-col justify-between rounded-lg border border-stone-200 p-3 transition-colors hover:border-stone-300 hover:bg-stone-100 dark:border-stone-800 dark:hover:border-stone-700 dark:hover:bg-stone-900"
            >
              <span class="flex items-center gap-1 font-mono text-xs text-stone-400 dark:text-stone-500">
                <Icon
                  name="lucide:arrow-left"
                  class="size-3.5 transition-transform group-hover:-translate-x-1"
                />
                上一篇
              </span>
              <span class="mt-2 text-sm font-medium leading-relaxed text-stone-700 dark:text-stone-200">
                {navigation.previous.data.title}
              </span>
            </a>
          )}
          {navigation.next && (
            <a
              href={getPostPath(navigation.next)}
              class="group flex min-h-20 flex-col justify-between rounded-lg border border-stone-200 p-3 text-right transition-colors hover:border-stone-300 hover:bg-stone-100 dark:border-stone-800 dark:hover:border-stone-700 dark:hover:bg-stone-900"
            >
              <span class="flex items-center justify-end gap-1 font-mono text-xs text-stone-400 dark:text-stone-500">
                下一篇
                <Icon
                  name="lucide:arrow-right"
                  class="size-3.5 transition-transform group-hover:translate-x-1"
                />
              </span>
              <span class="mt-2 text-sm font-medium leading-relaxed text-stone-700 dark:text-stone-200">
                {navigation.next.data.title}
              </span>
            </a>
          )}
        </nav>
      )
    }
    <div class="mt-8">
      <a
        href="/"
        class="flex items-center gap-1 text-stone-500 hover:text-stone-800 hover:underline transition-colors group dark:text-stone-400 dark:hover:text-stone-100"
      >
        <Icon
          name="lucide:arrow-left"
          class="size-4 transition-transform group-hover:-translate-x-1"
        />
        返回首页
      </a>
    </div>
  </article>
</Blog>
