---
import { getCollection } from 'astro:content'
import { Icon } from 'astro-icon/components'
import Blog from '../../layouts/Blog.astro'
import { SITE_TITLE } from '../../consts'
import { getPosts } from '../../lib/posts'
import { createTagItems, getTagPath } from '../../lib/tags'

const posts = await getPosts()
const tags = await getCollection('tags')
const tagItems = createTagItems(posts, tags)
---

<Blog title={`标签 - ${SITE_TITLE}`} description="按主题浏览日记岛的文章。">
  <section class="mt-6 flex flex-col gap-8">
    <header class="border-b border-stone-200 pb-4 dark:border-stone-800">
      <div class="flex items-center gap-2 text-stone-800 dark:text-stone-100">
        <Icon name="lucide:tags" class="size-6 text-blue-700 dark:text-sky-400" />
        <h1 class="text-3xl font-bold">标签</h1>
      </div>
      <p class="mt-2 font-mono text-m text-stone-500 dark:text-stone-400">
        共 {tagItems.length} 个
      </p>
      <p class="mt-3 text-stone-600 leading-relaxed dark:text-stone-300">
        按主题浏览文章。标签需要先声明，再在文章中引用。
      </p>
    </header>

    <ul class="grid gap-3 sm:grid-cols-2">
      {
        tagItems.map(tag => (
          <li>
            <a
              href={getTagPath(tag)}
              class="group flex min-h-28 flex-col justify-between rounded-lg border border-stone-200 p-4 transition-colors hover:border-stone-300 hover:bg-stone-100 dark:border-stone-800 dark:hover:border-stone-700 dark:hover:bg-stone-900"
            >
              <span>
                <span class="flex items-center gap-2 text-lg font-medium text-stone-800 transition-colors group-hover:text-stone-600 dark:text-stone-100 dark:group-hover:text-stone-300">
                  <Icon name="lucide:tag" class="size-4 text-blue-700 dark:text-sky-400" />
                  {tag.title}
                </span>
                {tag.description && (
                  <span class="mt-2 line-clamp-2 block text-sm leading-relaxed text-stone-500 dark:text-stone-400">
                    {tag.description}
                  </span>
                )}
              </span>
              <span class="mt-4 flex items-center justify-between font-mono text-xs text-stone-400 dark:text-stone-500">
                {tag.posts.length} 篇文章
                <Icon
                  name="lucide:arrow-right"
                  class="size-4 transition-transform group-hover:translate-x-1"
                />
              </span>
            </a>
          </li>
        ))
      }
    </ul>

    <div>
      <a
        href="/"
        class="flex items-center gap-1 text-stone-500 hover:text-stone-800 hover:underline transition-colors group dark:text-stone-400 dark:hover:text-stone-100"
      >
        <Icon
          name="lucide:arrow-left"
          class="size-4 transition-transform group-hover:-translate-x-1"
        />
        返回首页
      </a>
    </div>
  </section>
</Blog>
