---
import { getCollection } from 'astro:content'
import type { GetStaticPaths } from 'astro'
import { Icon } from 'astro-icon/components'
import Blog from '../../layouts/Blog.astro'
import { SITE_TITLE } from '../../consts'
import { createTagItems } from '../../lib/tags'
import { getPostPath } from '../../lib/posts'
import type { TagItem } from '../../lib/tags'

export const getStaticPaths = (async () => {
  const posts = await getCollection('posts')
  const tags = await getCollection('tags')
  const tagItems = createTagItems(posts, tags)

  return tagItems.map(tag => ({
    params: { tag: tag.slug },
    props: { tag },
  }))
}) satisfies GetStaticPaths

interface Props {
  tag: TagItem
}

const { tag } = Astro.props
---

<Blog title={`${tag.title} - 标签 - ${SITE_TITLE}`} description={tag.description}>
  <section class="mt-6 flex flex-col gap-8">
    <header class="border-b border-stone-200 pb-4 dark:border-stone-800">
      <div class="flex items-center gap-2 text-stone-800 dark:text-stone-100">
        <Icon name="lucide:tag" class="size-6 text-blue-700 dark:text-sky-400" />
        <h1 class="text-3xl font-bold">{tag.title}</h1>
      </div>
      <p class="mt-2 font-mono text-m text-stone-500 dark:text-stone-400">
        共 {tag.posts.length} 篇
      </p>
      {tag.description && (
        <p class="mt-3 text-stone-600 leading-relaxed dark:text-stone-300">{tag.description}</p>
      )}
    </header>

    <ul class="flex flex-col gap-4">
      {
        tag.posts.map(post => (
          <li class="group rounded-lg p-2 -mx-2 transition-colors hover:bg-stone-100 dark:hover:bg-stone-900">
            <a href={getPostPath(post)} class="block hover:underline">
              <h2 class="text-2xl font-medium text-stone-800 transition-colors group-hover:text-stone-600 dark:text-stone-100 dark:group-hover:text-stone-300">
                {post.data.title}
              </h2>
            </a>
            {post.data.description && (
              <p class="mt-1 line-clamp-2 text-m leading-relaxed text-stone-500 dark:text-stone-400">
                {post.data.description}
              </p>
            )}
            <time class="mt-2 flex shrink-0 items-center gap-1 font-mono text-m text-stone-400 dark:text-stone-500">
              <Icon name="lucide:calendar-arrow-up" class="size-4" />
              {post.data.pubDate.toLocaleDateString('zh-CN')}
            </time>
          </li>
        ))
      }
    </ul>

    <div>
      <a
        href="/"
        class="flex items-center gap-1 text-stone-500 hover:text-stone-800 hover:underline transition-colors group dark:text-stone-400 dark:hover:text-stone-100"
      >
        <Icon
          name="lucide:arrow-left"
          class="size-4 transition-transform group-hover:-translate-x-1"
        />
        返回首页
      </a>
    </div>
  </section>
</Blog>
