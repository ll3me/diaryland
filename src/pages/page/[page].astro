---
import { getCollection } from 'astro:content'
import Blog from '../../layouts/Blog.astro'
import { PAGE_SIZE, SERIES_PREVIEW_SIZE, SITE_TITLE } from '../../consts'
import { Icon } from 'astro-icon/components'
import type { GetStaticPaths } from 'astro'
import PostList from '../../components/PostList.astro'
import { createPostFeed, paginatePostFeed, sortPostsByDateDesc } from '../../lib/posts'
import type { FeedPage } from '../../lib/posts'

export const getStaticPaths = (async () => {
  const posts = sortPostsByDateDesc(await getCollection('posts'))
  const series = await getCollection('series')
  const feedItems = createPostFeed(posts, series)
  const pages = paginatePostFeed(feedItems, PAGE_SIZE, SERIES_PREVIEW_SIZE)

  return pages
    .filter(page => page.currentPage !== 1)
    .map(page => ({
      params: { page: String(page.currentPage) },
      props: { page },
    }))
}) satisfies GetStaticPaths

interface Props {
  page: FeedPage
}

const { page } = Astro.props
---

<Blog title={`第${page.currentPage}页 - ${SITE_TITLE}`}>
  <div class="mt-6 flex flex-col gap-10">
    <h2 class="text-3xl font-bold border-b border-stone-200 mb-4 dark:border-stone-800">
      最新文章 - 第{page.currentPage}页
    </h2>
    <PostList items={page.data} />
    <div class="flex flex-row mt-auto">
      <a
        class="text-lg text-stone-800 font-mono shrink-0 flex items-center gap-1 hover:text-stone-400 transition-colors group dark:text-stone-200 dark:hover:text-stone-500"
        href={`${page.currentPage === 2 ? '/' : `/page/${page.currentPage - 1}`}`}
      >
        <Icon
          name="lucide:arrow-left"
          class="size-5 transition-transform group-hover:-translate-x-1"
        />
        上一页
      </a>
      {
        page.currentPage < page.lastPage && (
          <a
            class="text-lg text-stone-800 font-mono shrink-0 flex items-center gap-1 ml-auto hover:text-stone-400 transition-colors group dark:text-stone-200 dark:hover:text-stone-500"
            href={`/page/${page.currentPage + 1}`}
          >
            下一页
            <Icon
              name="lucide:arrow-right"
              class="size-5 transition-transform group-hover:translate-x-1"
            />
          </a>
        )
      }
    </div>
  </div>
</Blog>
