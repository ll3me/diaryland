---
import { getCollection } from 'astro:content'
import Blog from '../layouts/Blog.astro'
import { PAGE_SIZE, SERIES_PREVIEW_SIZE, SITE_TITLE } from '../consts'
import { Icon } from 'astro-icon/components'
import PostList from '../components/PostList.astro'
import { createPostFeed, getPosts, paginatePostFeed, sortPostsByDateDesc } from '../lib/posts'

const posts = await getPosts()
const series = await getCollection('series')
const feedItems = createPostFeed(sortPostsByDateDesc(posts), series)
const pages = paginatePostFeed(feedItems, PAGE_SIZE, SERIES_PREVIEW_SIZE)
const page = pages[0]
---

<Blog title={`首页 - ${SITE_TITLE}`}>
  <div class="mt-6 flex flex-col gap-10">
    <h2 class="text-3xl font-bold border-b border-stone-200 mb-4 dark:border-stone-800">最新文章 - 首页</h2>
    <PostList items={page.data} />
    <div class="flex flex-row mt-auto">
      {
        page.currentPage < page.lastPage && (
          <a
            class="text-lg text-stone-800 font-mono shrink-0 flex items-center gap-1 ml-auto hover:text-stone-400 transition-colors group dark:text-stone-200 dark:hover:text-stone-500"
            href="/page/2"
          >
            下一页
            <Icon
              name="lucide:arrow-right"
              class="size-5 transition-transform group-hover:translate-x-1"
            />
          </a>
        )
      }
    </div>
  </div>
</Blog>
