---
import { getCollection } from 'astro:content'
import { Icon } from 'astro-icon/components'
import type { GetStaticPaths } from 'astro'
import Blog from '../../layouts/Blog.astro'
import { SITE_TITLE } from '../../consts'
import { createSeriesItems, getPosts, sortPostsByDateDesc } from '../../lib/posts'
import type { SeriesItem } from '../../lib/posts'

export const getStaticPaths = (async () => {
  const posts = sortPostsByDateDesc(await getPosts())
  const series = await getCollection('series')
  const seriesItems = createSeriesItems(posts, series)

  return seriesItems.map(series => ({
    params: { slug: series.slug },
    props: { series },
  }))
}) satisfies GetStaticPaths

interface Props {
  series: SeriesItem
}

const { series } = Astro.props
---

<Blog title={`${series.title} - ${SITE_TITLE}`} description={series.description}>
  <article class="mt-6 flex flex-col gap-8">
    <header class="border-b border-stone-200 pb-4 dark:border-stone-800">
      <div class="flex items-center gap-2 text-stone-800 dark:text-stone-100">
        <Icon name="lucide:rows-3" class="size-6 text-blue-700 dark:text-sky-400" />
        <h1 class="text-3xl font-bold">{series.title}</h1>
      </div>
      <p class="mt-2 font-mono text-m text-stone-500 dark:text-stone-400">
        共 {series.posts.length} 篇
      </p>
      <p class="mt-3 text-stone-600 leading-relaxed dark:text-stone-300">{series.description}</p>
    </header>

    <ol class="ml-3 flex flex-col gap-4 border-l border-stone-200 pl-4 dark:border-stone-800">
      {
        series.posts.map(post => (
          <li class="group rounded-lg p-2 -mx-2 transition-colors hover:bg-stone-100 dark:hover:bg-stone-900">
            <a href={`/post/${post.slug}`} class="block hover:underline">
              <h2 class="text-2xl font-medium text-stone-800 transition-colors group-hover:text-stone-600 dark:text-stone-100 dark:group-hover:text-stone-300">
                {post.data.title}
              </h2>
            </a>
            {post.data.description && (
              <p class="mt-1 line-clamp-2 text-m leading-relaxed text-stone-500 dark:text-stone-400">
                {post.data.description}
              </p>
            )}
            <time class="mt-2 flex shrink-0 items-center gap-1 font-mono text-m text-stone-400 dark:text-stone-500">
              <Icon name="lucide:calendar-arrow-up" class="size-4" />
              {post.data.pubDate.toLocaleDateString('zh-CN')}
            </time>
          </li>
        ))
      }
    </ol>

    <div>
      <a
        href="/"
        class="flex items-center gap-1 text-stone-500 hover:text-stone-800 hover:underline transition-colors group dark:text-stone-400 dark:hover:text-stone-100"
      >
        <Icon
          name="lucide:arrow-left"
          class="size-4 transition-transform group-hover:-translate-x-1"
        />
        返回首页
      </a>
    </div>
  </article>
</Blog>
